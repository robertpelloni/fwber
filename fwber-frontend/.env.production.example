# fwber.me Frontend Environment Variables
# Production Configuration Example
# Rename this file to .env.production on your server

# API Configuration
# IMPORTANT: Do not append /api. The frontend client adds that where needed.
NEXT_PUBLIC_API_URL=https://api.fwber.me

# Reverb Real-time
# These values should point at the websocket proxy host, not the backend API host.
NEXT_PUBLIC_REVERB_HOST=ws.fwber.me
NEXT_PUBLIC_REVERB_PORT=443
NEXT_PUBLIC_REVERB_SCHEME=https

# Push Notifications (VAPID)
# Get this from your backend: php artisan webpush:vapid
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_WITH_YOUR_KEY

# Feature Flags
NEXT_PUBLIC_FEATURE_CLIENT_FACE_BLUR=true
NEXT_PUBLIC_FEATURE_FACE_REVEAL=true
NEXT_PUBLIC_FEATURE_LOCAL_MEDIA_VAULT=true
NEXT_PUBLIC_FEATURE_VIDEO_CHAT=true
