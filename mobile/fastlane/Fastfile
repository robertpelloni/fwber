default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Ensure dependencies are up to date
    sh("cd .. && npm install")
    
    # Run the EAS build command for iOS (Profile: Preview)
    # Note: Requires EAS CLI installed globally and user logged in
    sh("cd .. && npx eas build --platform ios --profile preview --non-interactive")
    
    # EAS typically handles the TestFlight submission if configured in eas.json
    # but we can also use pilot here if we were doing local builds
    # pilot(ipa: "../app.ipa", skip_waiting_for_build_processing: true)
  end

  desc "Push a new release build to the App Store"
  lane :release do
    sh("cd .. && npm install")
    sh("cd .. && npx eas build --platform ios --profile production --auto-submit --non-interactive")
  end
end

platform :android do
  desc "Submit a new Beta Build to Crashlytics / Google Play Console"
  lane :beta do
    sh("cd .. && npm install")
    sh("cd .. && npx eas build --platform android --profile preview --non-interactive")
  end

  desc "Submit a new Release Build to Google Play Console"
  lane :release do
    sh("cd .. && npm install")
    sh("cd .. && npx eas build --platform android --profile production --auto-submit --non-interactive")
  end
end
