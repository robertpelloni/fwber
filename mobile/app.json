{
  "expo": {
    "name": "fwber",
    "slug": "fwber",
    "scheme": "fwber",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hyperfield.fwber",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "fwber needs access to your location to find nearby matches and venues.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "fwber needs 'Always On' location access to vibrate your phone when a highly compatible match walks past you, even if the app is closed.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "NFCReaderUsageDescription": "fwber needs access to NFC to verify physical profile exchanges and process tap-to-pay transactions."
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": ["NDEF"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.hyperfield.fwber",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "NFC"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "fwber needs 'Always On' location access to vibrate your phone when a highly compatible match walks past you, even if the app is closed.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ec4899"
        }
      ]
    ]
  }
}