model federation_follows {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  actor_uri  String    @db.VarChar(255)
  target_uri String    @db.VarChar(255)
  status     String    @default("pending") @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model federation_inbox {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  activity_id  String    @unique @db.VarChar(255)
  actor_uri    String    @db.VarChar(255)
  type         String    @db.VarChar(255)
  payload      Json
  processed_at DateTime? @db.Timestamp(0)
  created_at   DateTime? @db.Timestamp(0)
}

model federation_outbox {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  activity_id  String    @unique @db.VarChar(255)
  actor_uri    String    @db.VarChar(255)
  type         String    @db.VarChar(255)
  payload      Json
  delivered_at DateTime? @db.Timestamp(0)
  created_at   DateTime? @db.Timestamp(0)
}

model user_integrations {
  id                BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  user_id           BigInt            @db.UnsignedBigInt
  provider          String            @db.VarChar(50)
  provider_user_id  String            @db.VarChar(255)
  access_token      String            @db.Text
  refresh_token     String?           @db.Text
  token_expires_at  DateTime          @db.Timestamp(0)
  created_at        DateTime          @default(now()) @db.Timestamp(0)
  updated_at        DateTime          @default(now()) @updatedAt @db.Timestamp(0)
  user              users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  synced_contacts   synced_contacts[]

  @@unique([user_id, provider])
}

model synced_contacts {
  id                  BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  user_integration_id BigInt            @db.UnsignedBigInt
  first_name          String?           @db.VarChar(255)
  last_name           String?           @db.VarChar(255)
  emails              Json?
  phones              Json?
  raw_provider_data   Json?
  synced_at           DateTime          @default(now()) @db.Timestamp(0)
  user_integration    user_integrations @relation(fields: [user_integration_id], references: [id], onDelete: Cascade)
}

model autonomous_actions {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  task       String    @db.VarChar(255)
  status     String    @db.VarChar(50)
  metadata   Json?
  created_at DateTime  @default(now()) @db.Timestamp(0)

  @@index([created_at])
}

model autonomous_settings {
  key        String    @id @db.VarChar(100)
  value      String    @db.VarChar(255)
  updated_at DateTime  @updatedAt @db.Timestamp(0)
}

model matching_questions {
  id                  BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  text                String                 @db.Text
  category            String                 @db.VarChar(255)
  priority            Int                    @default(0)
  is_active           Boolean                @default(true)
  created_at          DateTime?              @db.Timestamp(0)
  updated_at          DateTime?              @db.Timestamp(0)
  matching_options    matching_options[]
  user_matching_answers user_matching_answers[]
}

model matching_options {
  id                  BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  question_id         BigInt                 @db.UnsignedBigInt
  text                String                 @db.Text
  created_at          DateTime?              @db.Timestamp(0)
  updated_at          DateTime?              @db.Timestamp(0)
  matching_questions  matching_questions     @relation(fields: [question_id], references: [id], onDelete: Cascade)
  user_matching_answers user_matching_answers[] @relation("chosen_option")
}

model user_matching_answers {
  id                  BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  user_id             BigInt                 @db.UnsignedBigInt
  question_id         BigInt                 @db.UnsignedBigInt
  chosen_option_id    BigInt                 @db.UnsignedBigInt
  accepted_option_ids Json?
  importance          Int                    @default(1)
  explanation         String?                @db.Text
  created_at          DateTime?              @db.Timestamp(0)
  updated_at          DateTime?              @db.Timestamp(0)

  users               users                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  matching_questions  matching_questions     @relation(fields: [question_id], references: [id], onDelete: Cascade)
  chosen_option       matching_options       @relation("chosen_option", fields: [chosen_option_id], references: [id], onDelete: Cascade)

  @@unique([user_id, question_id])
}
