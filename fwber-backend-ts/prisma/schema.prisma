generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MODERATOR
  MERCHANT
}

enum Tier {
  FREE
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model User {
  id                        Int       @id @default(autoincrement())
  role                      UserRole  @default(USER)
  name                      String
  email                     String    @unique
  actor_uri                 String?
  is_remote                 Boolean   @default(false)
  referral_code             String?   @unique
  golden_tickets_remaining  Int       @default(0)
  referrer_id               Int?
  referrer                  User?     @relation("Referrals", fields: [referrer_id], references: [id])
  referrals                 User[]    @relation("Referrals")
  wallet_address            String?
  merchant_secret           String?
  merchant_name             String?
  token_balance             Decimal   @default(0.0000) @db.Decimal(18, 4)
  avatar_url                String?
  email_verified_at         DateTime?
  onboarding_completed_at   DateTime?
  password                  String
  decoy_password            String?
  decoy_user_id             Int?
  is_decoy                  Boolean   @default(false)
  two_factor_secret         String?
  two_factor_recovery_codes String?
  two_factor_confirmed_at   DateTime?
  remember_token            String?
  current_streak            Int       @default(0)
  last_active_at            DateTime? @default(now())
  created_at                DateTime  @default(now())
  updated_at                DateTime  @updatedAt
  tier                      Tier      @default(FREE)
  tier_expires_at           DateTime?
  unlimited_swipes          Boolean   @default(false)
  last_daily_bonus_at       DateTime?

  // Relationships
  profile           UserProfile?
  photos            Photo[]
  merchant_profile  MerchantProfile?
  boosts            Boost[]
  events_created    Event[]           @relation("EventsCreated")
  events_attending  EventAttendee[]
  groups_created    Group[]           @relation("GroupsCreated")
  groups            GroupMember[]
  notifications     Notification[]
  sent_messages     Message[]         @relation("SentMessages")
  received_messages Message[]         @relation("ReceivedMessages")
  subscriptions     Subscription[]
  gifts_sent        UserGift[]        @relation("GiftsSent")
  gifts_received    UserGift[]        @relation("GiftsReceived")
  match_actions     MatchAction[]
  device_tokens     DeviceToken[]
  journals          Journal[]
  token_transactions TokenTransaction[]
  match_bounties     MatchBounty[]
  match_assists_made MatchAssist[]      @relation("MatchmakerAssists")
  match_assists_received MatchAssist[]  @relation("SubjectAssists")
  match_assists_target   MatchAssist[]  @relation("TargetAssists")
  geo_spoof_detections   GeoSpoofDetection[]
  
  // Self-referential for friends (simplified for now)
  friends           User[]            @relation("UserFriends")
  friends_of        User[]            @relation("UserFriends")

  @@index([email])
  @@index([referral_code])
}

model UserProfile {
  id           Int      @id @default(autoincrement())
  user_id      Int      @unique
  user         User     @relation(fields: [user_id], references: [id])
  display_name String?
  bio          String?  @db.Text
  birthdate    DateTime?
  gender       String?
  city         String?
  neighborhood String?
  latitude     Float?
  longitude    Float?
  is_id_verified Boolean  @default(false)
  zk_id_issuer  String?
  id_verified_at DateTime?
  id_verification_metadata Json?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Photo {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  url         String
  is_primary  Boolean  @default(false)
  is_private  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model MerchantProfile {
  id          Int      @id @default(autoincrement())
  user_id     Int      @unique
  user        User     @relation(fields: [user_id], references: [id])
  store_name  String
  description String?  @db.Text
  address     String?
  website     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Boost {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  type        String
  expires_at  DateTime
  created_at  DateTime @default(now())
}

model Event {
  id                  Int             @id @default(autoincrement())
  created_by_user_id  Int
  creator             User            @relation("EventsCreated", fields: [created_by_user_id], references: [id])
  title               String
  description         String?         @db.Text
  start_time          DateTime
  end_time            DateTime?
  location_name       String?
  latitude            Float?
  longitude           Float?
  attendees           EventAttendee[]
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
}

model EventAttendee {
  id         Int      @id @default(autoincrement())
  event_id   Int
  event      Event    @relation(fields: [event_id], references: [id])
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  status     String   @default("pending")
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([event_id, user_id])
}

model Group {
  id                  Int           @id @default(autoincrement())
  name                String
  description         String?       @db.Text
  created_by_user_id  Int
  creator             User          @relation("GroupsCreated", fields: [created_by_user_id], references: [id])
  members             GroupMember[]
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt
}

model GroupMember {
  id         Int      @id @default(autoincrement())
  group_id   Int
  group      Group    @relation(fields: [group_id], references: [id])
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  role       String   @default("member")
  joined_at  DateTime @default(now())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([group_id, user_id])
}

model Message {
  id          Int      @id @default(autoincrement())
  sender_id   Int
  sender      User     @relation("SentMessages", fields: [sender_id], references: [id])
  receiver_id Int
  receiver    User     @relation("ReceivedMessages", fields: [receiver_id], references: [id])
  content     String   @db.Text
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  type       String
  data       Json
  read_at    DateTime?
  created_at DateTime @default(now())
}

model Subscription {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  plan_id    String
  status     String
  expires_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model UserGift {
  id          Int      @id @default(autoincrement())
  sender_id   Int
  sender      User     @relation("GiftsSent", fields: [sender_id], references: [id])
  receiver_id Int
  receiver    User     @relation("GiftsReceived", fields: [receiver_id], references: [id])
  gift_type   String
  message     String?
  created_at  DateTime @default(now())
}

model MatchAction {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  target_id  Int
  action     String   // e.g., "like", "pass", "superlike"
  created_at DateTime @default(now())
}

model DeviceToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  token      String   @unique
  platform   String   // ios, android, web
  created_at DateTime @default(now())
}

model Journal {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  title      String?
  content    String   @db.Text
  is_private Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model TokenTransaction {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  amount      Decimal  @db.Decimal(18, 4)
  type        String
  description String
  metadata    Json?
  created_at  DateTime @default(now())
}

model MatchBounty {
  id            Int           @id @default(autoincrement())
  user_id       Int
  user          User          @relation(fields: [user_id], references: [id])
  slug          String        @unique
  token_reward  Int
  status        String        @default("active") // active, fulfilled, expired, cancelled
  description   String?       @db.Text
  expires_at    DateTime?
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  assists       MatchAssist[]
}

model MatchAssist {
  id              Int          @id @default(autoincrement())
  match_bounty_id Int?
  bounty          MatchBounty? @relation(fields: [match_bounty_id], references: [id])
  matchmaker_id   Int
  matchmaker      User         @relation("MatchmakerAssists", fields: [matchmaker_id], references: [id])
  subject_id      Int
  subject         User         @relation("SubjectAssists", fields: [subject_id], references: [id])
  target_id       Int
  target          User         @relation("TargetAssists", fields: [target_id], references: [id])
  status          String       @default("suggested") // suggested, viewed, matched
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  @@unique([matchmaker_id, subject_id, target_id])
}

model GeoSpoofDetection {
  id                 Int      @id @default(autoincrement())
  user_id            Int
  user               User     @relation(fields: [user_id], references: [id])
  ip_address         String
  latitude           Float
  longitude          Float
  ip_latitude        Float?
  ip_longitude       Float?
  distance_km        Int?
  velocity_kmh       Int?
  suspicion_score    Int
  detection_flags    Json
  is_confirmed_spoof Boolean  @default(false)
  detected_at        DateTime @default(now())
}



