  @@unique([aggregate_uuid, aggregate_type, version], map: "domain_events_aggregate_uuid_aggregate_type_version_unique")
  @@index([aggregate_type], map: "domain_events_aggregate_type_index")
  @@index([aggregate_uuid], map: "domain_events_aggregate_uuid_index")
  @@index([recorded_at], map: "domain_events_recorded_at_index")
