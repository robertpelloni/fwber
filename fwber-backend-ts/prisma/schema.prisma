  vouches_vouches_from_user_idTousers                                  vouches[]                              @relation("vouches_from_user_idTousers")
  vouches_vouches_to_user_idTousers                                    vouches[]                              @relation("vouches_to_user_idTousers")
  wallet_transactions                                                  wallet_transactions[]
  zk_proximity_proofs                                                  zk_proximity_proofs[]
  user_integrations                                                    user_integrations[]
  user_matching_answers                                                user_matching_answers[]

  @@index([decoy_user_id], map: "users_decoy_user_id_foreign")
  @@index([last_active_at], map: "users_last_active_at_index")
  @@index([last_seen_at], map: "users_last_seen_at_index")
  @@index([referrer_id], map: "users_referrer_id_index")
}

model venue_checkins {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id        BigInt    @db.UnsignedBigInt
  venue_id       BigInt    @db.UnsignedBigInt
  message        String?   @db.Text
  checked_out_at DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "venue_checkins_user_id_foreign")
  venues         venues    @relation(fields: [venue_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "venue_checkins_venue_id_foreign")

  @@index([user_id, created_at], map: "venue_checkins_user_id_created_at_index")
  @@index([venue_id, checked_out_at], map: "venue_checkins_venue_id_checked_out_at_index")
}

model venues {
  id                      BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  name                    String                     @db.VarChar(255)
  email                   String                     @unique(map: "venues_email_unique") @db.VarChar(255)
  email_verified_at       DateTime?                  @db.Timestamp(0)
  password                String                     @db.VarChar(255)
  business_type           String?                    @db.VarChar(255)
  description             String?                    @db.Text
  address                 String?                    @db.VarChar(255)
  city                    String?                    @db.VarChar(255)
  state                   String?                    @db.VarChar(255)
  country                 String                     @default("US") @db.VarChar(255)
  zip_code                String?                    @db.VarChar(255)
  latitude                Decimal?                   @db.Decimal(10, 8)
  longitude               Decimal?                   @db.Decimal(11, 8)
  phone                   String?                    @db.VarChar(255)
  website                 String?                    @db.VarChar(255)
  operating_hours         Json?
  max_capacity            Int                        @default(100)
  commission_rate         Decimal                    @default(5.00) @db.Decimal(5, 2)
  verification_status     venues_verification_status @default(pending)
  subscription_tier       venues_subscription_tier   @default(starter)
  subscription_expires_at DateTime?                  @db.Timestamp(0)
  is_active               Boolean                    @default(true)
  features                Json?
  created_at              DateTime?                  @db.Timestamp(0)
  updated_at              DateTime?                  @db.Timestamp(0)
  venue_checkins          venue_checkins[]
}

model video_calls {
  id                                   BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  caller_id                            BigInt             @db.UnsignedBigInt
  receiver_id                          BigInt             @db.UnsignedBigInt
  started_at                           DateTime?          @db.Timestamp(0)
  ended_at                             DateTime?          @db.Timestamp(0)
  status                               video_calls_status @default(initiated)
  duration                             Int?
  created_at                           DateTime?          @db.Timestamp(0)
  updated_at                           DateTime?          @db.Timestamp(0)
  users_video_calls_caller_idTousers   users              @relation("video_calls_caller_idTousers", fields: [caller_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "video_calls_caller_id_foreign")
  users_video_calls_receiver_idTousers users              @relation("video_calls_receiver_idTousers", fields: [receiver_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "video_calls_receiver_id_foreign")

  @@index([caller_id, created_at], map: "video_calls_caller_id_created_at_index")
  @@index([receiver_id, created_at], map: "video_calls_receiver_id_created_at_index")
}

model viral_contents {
  id             String    @id @db.Char(36)
  share_id       String?   @unique @db.VarChar(36)
  user_id        BigInt    @db.UnsignedBigInt
  type           String    @db.VarChar(255)
  content        Json
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  views          Int       @default(0) @db.UnsignedInt
  reward_claimed Boolean   @default(false)
  users          users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "viral_contents_user_id_foreign")

  @@index([user_id], map: "viral_contents_user_id_foreign")
}

model trust_scores {
  user_id    BigInt   @id @db.UnsignedBigInt
  score      Decimal  @db.Decimal(5, 2)
  level      String   @db.VarChar(32)
  factors    Json?
  updated_at DateTime @updatedAt @db.Timestamp(0)

  @@index([score])
  @@index([level])
}

model vouches {
  id                                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  to_user_id                        BigInt    @db.UnsignedBigInt
  from_user_id                      BigInt?   @db.UnsignedBigInt
  voucher_name                      String?   @db.VarChar(255)
  type                              String    @db.VarChar(255)
  relationship_type                 String?   @db.VarChar(255)
  comment                           String?   @db.Text
  is_verified                       Boolean   @default(false)
  ip_address                        String?   @db.VarChar(255)
  created_at                        DateTime? @db.Timestamp(0)
  updated_at                        DateTime? @db.Timestamp(0)
  users_vouches_from_user_idTousers users?    @relation("vouches_from_user_idTousers", fields: [from_user_id], references: [id], onUpdate: NoAction, map: "vouches_from_user_id_foreign")
  users_vouches_to_user_idTousers   users     @relation("vouches_to_user_idTousers", fields: [to_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "vouches_to_user_id_foreign")

  @@index([from_user_id], map: "vouches_from_user_id_foreign")
  @@index([to_user_id, type], map: "vouches_to_user_id_type_index")
}

model wallet_transactions {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt    @db.UnsignedBigInt
  amount      Decimal   @db.Decimal(10, 2)
  type        String    @db.VarChar(255)
  description String    @db.VarChar(255)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "wallet_transactions_user_id_foreign")

  @@index([user_id, created_at], map: "wallet_transactions_user_id_created_at_index")
}

model zk_proximity_proofs {
  id                 BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id            BigInt    @db.UnsignedBigInt
  target_entity_type String    @db.VarChar(255)
  target_entity_id   BigInt    @db.UnsignedBigInt
  proof_hash         String    @db.Text
  is_verified        Boolean   @default(false)
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  users              users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "zk_proximity_proofs_user_id_foreign")

  @@index([target_entity_type, target_entity_id], map: "zk_proximity_proofs_target_entity_type_target_entity_id_index")
  @@index([user_id], map: "zk_proximity_proofs_user_id_foreign")
}

