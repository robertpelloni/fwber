generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model relationship_links {
  id                   BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id              BigInt    @db.UnsignedBigInt
  related_user_id      BigInt?   @db.UnsignedBigInt
  relationship_type    String    @db.VarChar(255)
  visibility           String    @default("public") @db.VarChar(255)
  note                 String?   @db.Text
  is_confirmed         Boolean   @default(false)
  requested_by_user_id BigInt    @db.UnsignedBigInt
  confirmed_at         DateTime? @db.Timestamp(0)
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)

  users_relationship_links_user_idTousers         users  @relation("relationship_links_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_relationship_links_related_user_idTousers users? @relation("relationship_links_related_user_idTousers", fields: [related_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@index([related_user_id])
}

model achievements {
  id                BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  slug              String              @unique(map: "achievements_slug_unique") @db.VarChar(255)
  name              String              @db.VarChar(255)
  description       String?             @db.Text
  icon              String?             @db.VarChar(255)
  token_reward      Int                 @default(0)
  criteria          Json?
  created_at        DateTime?           @db.Timestamp(0)
  updated_at        DateTime?           @db.Timestamp(0)
  user_achievements user_achievements[]
}

model api_tokens {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  name         String?   @db.VarChar(255)
  token        String    @unique(map: "api_tokens_token_unique") @db.VarChar(64)
  last_used_at DateTime? @db.Timestamp(0)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "api_tokens_user_id_foreign")

  @@index([user_id], map: "api_tokens_user_id_foreign")
}

model attendees {
  id                                                  BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  email                                               String                @unique(map: "attendees_email_unique") @db.VarChar(255)
  email_verified_at                                   DateTime?             @db.Timestamp(0)
  password                                            String                @db.VarChar(255)
  display_name                                        String?               @db.VarChar(255)
  birth_date                                          DateTime              @db.Date
  gender                                              attendees_gender
  orientation                                         attendees_orientation
  city                                                String?               @db.VarChar(255)
  state                                               String?               @db.VarChar(255)
  country                                             String                @default("US") @db.VarChar(255)
  zip_code                                            String?               @db.VarChar(255)
  latitude                                            Decimal?              @db.Decimal(10, 8)
  longitude                                           Decimal?              @db.Decimal(11, 8)
  physical_attributes                                 Json?
  interests                                           Json?
  experience_level                                    Json?
  bio                                                 String?               @db.Text
  looking_for                                         Json?
  is_verified                                         Boolean               @default(false)
  verification_method                                 String?               @db.VarChar(255)
  is_premium                                          Boolean               @default(false)
  premium_expires_at                                  DateTime?             @db.Timestamp(0)
  privacy_settings                                    Json?
  avatar_url                                          String?               @db.VarChar(255)
  is_active                                           Boolean               @default(true)
  last_active_at                                      DateTime?             @db.Timestamp(0)
  created_at                                          DateTime?             @db.Timestamp(0)
  updated_at                                          DateTime?             @db.Timestamp(0)
  event_matches_event_matches_attendee1_idToattendees event_matches[]       @relation("event_matches_attendee1_idToattendees")
  event_matches_event_matches_attendee2_idToattendees event_matches[]       @relation("event_matches_attendee2_idToattendees")

  @@index([city, state], map: "attendees_city_state_index")
  @@index([gender, orientation], map: "attendees_gender_orientation_index")
  @@index([is_verified, is_active], map: "attendees_is_verified_is_active_index")
}

model audio_room_participants {
  id            BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  audio_room_id BigInt                       @db.UnsignedBigInt
  user_id       BigInt                       @db.UnsignedBigInt
  role          audio_room_participants_role @default(listener)
  is_muted      Boolean                      @default(true)
  created_at    DateTime?                    @db.Timestamp(0)
  updated_at    DateTime?                    @db.Timestamp(0)
  audio_rooms   audio_rooms                  @relation(fields: [audio_room_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "audio_room_participants_audio_room_id_foreign")
  users         users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "audio_room_participants_user_id_foreign")

  @@unique([audio_room_id, user_id], map: "audio_room_participants_audio_room_id_user_id_unique")
  @@index([user_id], map: "audio_room_participants_user_id_foreign")
}

model audio_rooms {
  id                      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  name                    String                    @db.VarChar(255)
  description             String?                   @db.Text
  created_by              BigInt                    @db.UnsignedBigInt
  is_active               Boolean                   @default(true)
  created_at              DateTime?                 @db.Timestamp(0)
  updated_at              DateTime?                 @db.Timestamp(0)
  audio_room_participants audio_room_participants[]
  users                   users                     @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "audio_rooms_created_by_foreign")

  @@index([created_by], map: "audio_rooms_created_by_foreign")
}

model blocks {
  id                             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  blocker_id                     BigInt    @db.UnsignedBigInt
  blocked_id                     BigInt    @db.UnsignedBigInt
  created_at                     DateTime? @db.Timestamp(0)
  updated_at                     DateTime? @db.Timestamp(0)
  users_blocks_blocked_idTousers users     @relation("blocks_blocked_idTousers", fields: [blocked_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blocks_blocked_id_foreign")
  users_blocks_blocker_idTousers users     @relation("blocks_blocker_idTousers", fields: [blocker_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "blocks_blocker_id_foreign")

  @@unique([blocker_id, blocked_id], map: "blocks_blocker_id_blocked_id_unique")
  @@index([blocked_id], map: "blocks_blocked_id_foreign")
}

model boosts {
  id         BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt            @db.UnsignedBigInt
  started_at DateTime?         @db.Timestamp(0)
  expires_at DateTime?         @db.Timestamp(0)
  boost_type boosts_boost_type @default(standard)
  status     boosts_status     @default(active)
  created_at DateTime?         @db.Timestamp(0)
  updated_at DateTime?         @db.Timestamp(0)
  users      users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "boosts_user_id_foreign")

  @@index([expires_at], map: "boosts_expires_at_index")
  @@index([boost_type, created_at], map: "boosts_type_created_index")
  @@index([user_id, status], map: "boosts_user_id_status_index")
}

model bulletin_board_users {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  bulletin_board_id BigInt    @db.UnsignedBigInt
  user_id           BigInt    @db.UnsignedBigInt
  last_seen_at      DateTime  @default(now()) @db.Timestamp(0)
  is_online         Boolean   @default(true)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  users             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "bulletin_board_users_user_id_foreign")

  @@unique([bulletin_board_id, user_id], map: "bulletin_board_users_bulletin_board_id_user_id_unique")
  @@index([user_id], map: "bulletin_board_users_user_id_foreign")
}

model burner_links {
  id                                   BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  creator_id                           BigInt     @db.UnsignedBigInt
  scanner_id                           BigInt?    @db.UnsignedBigInt
  chatroom_id                          BigInt?    @db.UnsignedBigInt
  token                                String     @unique(map: "burner_links_token_unique") @db.VarChar(64)
  expires_at                           DateTime   @db.Timestamp(0)
  used_at                              DateTime?  @db.Timestamp(0)
  created_at                           DateTime?  @db.Timestamp(0)
  updated_at                           DateTime?  @db.Timestamp(0)
  chatrooms                            chatrooms? @relation(fields: [chatroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "burner_links_chatroom_id_foreign")
  users_burner_links_creator_idTousers users      @relation("burner_links_creator_idTousers", fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "burner_links_creator_id_foreign")
  users_burner_links_scanner_idTousers users?     @relation("burner_links_scanner_idTousers", fields: [scanner_id], references: [id], onUpdate: NoAction, map: "burner_links_scanner_id_foreign")

  @@index([chatroom_id], map: "burner_links_chatroom_id_foreign")
  @@index([creator_id], map: "burner_links_creator_id_foreign")
  @@index([scanner_id], map: "burner_links_scanner_id_foreign")
}

model cache {
  key        String @id @db.VarChar(255)
  value      String @db.MediumText
  expiration Int
}

model cache_locks {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration Int
}

model chatroom_members {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  chatroom_id BigInt    @db.UnsignedBigInt
  user_id     BigInt    @db.UnsignedBigInt
  role        String    @default("member") @db.VarChar(255)
  is_muted    Boolean   @default(false)
  joined_at   DateTime  @default(now()) @db.Timestamp(0)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
  chatrooms   chatrooms @relation(fields: [chatroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_members_chatroom_id_foreign")
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_members_user_id_foreign")

  @@unique([chatroom_id, user_id], map: "chatroom_members_chatroom_id_user_id_unique")
  @@index([user_id], map: "chatroom_members_user_id_foreign")
}

model chatroom_message_mentions {
  id                  BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  chatroom_message_id BigInt            @db.UnsignedBigInt
  mentioned_user_id   BigInt            @db.UnsignedBigInt
  position            Int               @db.UnsignedInt
  length              Int               @db.UnsignedInt
  created_at          DateTime?         @db.Timestamp(0)
  updated_at          DateTime?         @db.Timestamp(0)
  chatroom_messages   chatroom_messages @relation(fields: [chatroom_message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_message_mentions_chatroom_message_id_foreign")
  users               users             @relation(fields: [mentioned_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_message_mentions_mentioned_user_id_foreign")

  @@index([mentioned_user_id], map: "chatroom_message_mentions_mentioned_user_id_foreign")
  @@index([chatroom_message_id, mentioned_user_id], map: "cmm_message_user_idx")
}

model chatroom_message_reactions {
  id                  BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  chatroom_message_id BigInt            @db.UnsignedBigInt
  user_id             BigInt            @db.UnsignedBigInt
  emoji               String            @db.VarChar(32)
  created_at          DateTime?         @db.Timestamp(0)
  updated_at          DateTime?         @db.Timestamp(0)
  chatroom_messages   chatroom_messages @relation(fields: [chatroom_message_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_message_reactions_chatroom_message_id_foreign")
  users               users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_message_reactions_user_id_foreign")

  @@index([chatroom_message_id, emoji], map: "chatroom_message_reactions_chatroom_message_id_emoji_index")
  @@index([user_id, created_at], map: "chatroom_message_reactions_user_id_created_at_index")
}

model chatroom_messages {
  id                         BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  chatroom_id                BigInt                       @db.UnsignedBigInt
  user_id                    BigInt                       @db.UnsignedBigInt
  content                    String                       @db.Text
  created_at                 DateTime?                    @db.Timestamp(0)
  updated_at                 DateTime?                    @db.Timestamp(0)
  chatroom_message_mentions  chatroom_message_mentions[]
  chatroom_message_reactions chatroom_message_reactions[]
  chatrooms                  chatrooms                    @relation(fields: [chatroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_messages_chatroom_id_foreign")
  users                      users                        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatroom_messages_user_id_foreign")

  @@index([chatroom_id], map: "chatroom_messages_chatroom_id_foreign")
  @@index([user_id], map: "chatroom_messages_user_id_foreign")
}

model chatrooms {
  id                BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  name              String              @db.VarChar(100)
  description       String?             @db.VarChar(500)
  type              chatrooms_type
  category          String?             @db.VarChar(50)
  created_by        BigInt              @db.UnsignedBigInt
  is_public         Boolean             @default(true)
  is_active         Boolean             @default(true)
  member_count      Int                 @default(0)
  message_count     Int                 @default(0)
  last_activity_at  DateTime?           @db.Timestamp(0)
  created_at        DateTime?           @db.Timestamp(0)
  updated_at        DateTime?           @db.Timestamp(0)
  burner_links      burner_links[]
  chatroom_members  chatroom_members[]
  chatroom_messages chatroom_messages[]
  users             users               @relation(fields: [created_by], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "chatrooms_created_by_foreign")

  @@index([created_by], map: "chatrooms_created_by_foreign")
}

model clickstream_events {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt?   @db.UnsignedBigInt
  session_id String    @db.VarChar(255)
  event_name String    @db.VarChar(255)
  payload    Json?
  url        String?   @db.VarChar(255)
  ip_address String?   @db.VarChar(255)
  user_agent String?   @db.Text
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  users      users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "clickstream_events_user_id_foreign")

  @@index([event_name], map: "clickstream_events_event_name_index")
  @@index([session_id], map: "clickstream_events_session_id_index")
  @@index([user_id], map: "clickstream_events_user_id_foreign")
}

model content_unlocks {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  content_type String    @db.VarChar(255)
  content_id   String    @db.VarChar(255)
  cost         Decimal   @db.Decimal(8, 2)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "content_unlocks_user_id_foreign")

  @@unique([user_id, content_type, content_id], map: "content_unlocks_user_id_content_type_content_id_unique")
  @@index([user_id, content_type, content_id], map: "content_unlocks_user_id_content_type_content_id_index")
}

model creator_subscriptions {
  id                                            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id                                       BigInt    @db.UnsignedBigInt
  creator_id                                    BigInt    @db.UnsignedBigInt
  expires_at                                    DateTime  @db.Timestamp(0)
  cost                                          Int
  status                                        String    @default("active") @db.VarChar(255)
  created_at                                    DateTime? @db.Timestamp(0)
  updated_at                                    DateTime? @db.Timestamp(0)
  users_creator_subscriptions_creator_idTousers users     @relation("creator_subscriptions_creator_idTousers", fields: [creator_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "creator_subscriptions_creator_id_foreign")
  users_creator_subscriptions_user_idTousers    users     @relation("creator_subscriptions_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "creator_subscriptions_user_id_foreign")

  @@unique([user_id, creator_id], map: "creator_subscriptions_user_id_creator_id_unique")
  @@index([creator_id], map: "creator_subscriptions_creator_id_foreign")
}

model daily_active_users {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt    @db.UnsignedBigInt
  date       DateTime  @db.Date
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "daily_active_users_user_id_foreign")

  @@unique([user_id, date], map: "daily_active_users_user_id_date_unique")
  @@index([date], map: "daily_active_users_date_index")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model date_feedback {
  id                                           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  match_id                                     BigInt    @db.UnsignedBigInt
  reporting_user_id                            BigInt    @db.UnsignedBigInt
  subject_user_id                              BigInt    @db.UnsignedBigInt
  rating                                       Int       @db.TinyInt
  feedback_text                                String?   @db.Text
  safety_concerns                              Boolean   @default(false)
  created_at                                   DateTime? @db.Timestamp(0)
  updated_at                                   DateTime? @db.Timestamp(0)
  matches                                      matches   @relation(fields: [match_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "date_feedback_match_id_foreign")
  users_date_feedback_reporting_user_idTousers users     @relation("date_feedback_reporting_user_idTousers", fields: [reporting_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "date_feedback_reporting_user_id_foreign")
  users_date_feedback_subject_user_idTousers   users     @relation("date_feedback_subject_user_idTousers", fields: [subject_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "date_feedback_subject_user_id_foreign")

  @@unique([match_id, reporting_user_id], map: "date_feedback_match_id_reporting_user_id_unique")
  @@index([reporting_user_id], map: "date_feedback_reporting_user_id_foreign")
  @@index([subject_user_id], map: "date_feedback_subject_user_id_foreign")
}

model device_tokens {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt    @db.UnsignedBigInt
  token      String    @unique(map: "device_tokens_token_unique") @db.VarChar(255)
  type       String?   @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "device_tokens_user_id_foreign")

  @@index([user_id], map: "device_tokens_user_id_foreign")
}

model domain_events {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  aggregate_uuid String   @db.Char(36)
  aggregate_type String   @db.VarChar(255)
  version        Int      @db.UnsignedInt
  event_type     String   @db.VarChar(255)
