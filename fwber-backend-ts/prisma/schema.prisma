model emergency_contacts {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  name         String    @db.VarChar(255)
  phone        String?   @db.VarChar(255)
  email        String?   @db.VarChar(255)
  relationship String?   @db.VarChar(255)
  is_primary   Boolean   @default(false)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  users        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "emergency_contacts_user_id_foreign")

  @@index([user_id], map: "emergency_contacts_user_id_foreign")
}

model event_attendees {
  id             BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  event_id       BigInt                 @db.UnsignedBigInt
  user_id        BigInt                 @db.UnsignedBigInt
  status         event_attendees_status @default(attending)
  created_at     DateTime?              @db.Timestamp(0)
  updated_at     DateTime?              @db.Timestamp(0)
  paid           Boolean                @default(false)
  payment_method String?                @db.VarChar(255)
  transaction_id String?                @db.VarChar(255)
  events         events                 @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_attendees_event_id_foreign")
  users          users                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_attendees_user_id_foreign")

  @@unique([event_id, user_id], map: "event_attendees_event_id_user_id_unique")
  @@index([event_id, status], map: "event_attendees_event_status_index")
  @@index([user_id, status], map: "event_attendees_user_status_index")
}

model event_invitations {
  id                                        BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  event_id                                  BigInt                   @db.UnsignedBigInt
  inviter_id                                BigInt                   @db.UnsignedBigInt
  invitee_id                                BigInt                   @db.UnsignedBigInt
  status                                    event_invitations_status @default(pending)
  created_at                                DateTime?                @db.Timestamp(0)
  updated_at                                DateTime?                @db.Timestamp(0)
  events                                    events                   @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_invitations_event_id_foreign")
  users_event_invitations_invitee_idTousers users                    @relation("event_invitations_invitee_idTousers", fields: [invitee_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "event_invitations_invitee_id_foreign")
