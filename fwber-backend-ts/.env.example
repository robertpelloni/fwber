# fwber-backend-ts .env.example
# OkCupid Matching Engine (v2.1.5)

PORT=4000
NODE_ENV=development
DATABASE_URL="mysql://fwber:password@localhost:3306/fwber"
UPLOAD_DIR="uploads"

# Authentication
JWT_SECRET="CHANGE_ME_STAGING_SECRET"

# External Services
OPENAI_API_KEY="sk-..." # Optional for AI Wingman/Matching Questions
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Frontend URL
FRONTEND_URL="https://fwber.me"

# Email Infrastructure
# If using Resend API:
RESEND_API_KEY="re_..."
# If using SMTP directly (Postfix on Hetzner, Mailgun, SendGrid, etc.):
MAIL_HOST="smtp.example.com"
MAIL_PORT="587"
MAIL_USER="user"
MAIL_PASS="password"
MAIL_FROM="noreply@fwber.me"

# Stripe Payments Infrastructure
# Test Mode Keys: (pk_test_... / sk_test_...)
# Live Mode Keys: (pk_live_... / sk_live_...)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
